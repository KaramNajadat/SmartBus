# Copy this file to .env.local and fill in the values for your Firebase project.
# Get the values from: Firebase Console → Project Settings → General → Your apps → Web app config.
#
# Note: Firebase Web API keys are PUBLIC identifiers, not secrets. They identify
# the project but do not grant access on their own — Firestore security rules and
# Firebase Auth do the actual access control. This file is committed as a schema
# reference; .env.local (with your real values) is gitignored.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
